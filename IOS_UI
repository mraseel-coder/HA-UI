                        else if (s && s.state === 'off') statusHtml = '<span style="color:#f87171">● Offline</span>';

                        const online = s && s.state === 'on';

                        const btn = (label, icon, color, bg, border, enabled, action) => `
                          <div onclick="event.stopPropagation(); ${enabled ? action : 'void(0)'}"
                            ontouchend="event.preventDefault(); event.stopPropagation(); ${enabled ? action : ''}"
                            style="flex:1;min-width:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;
                            padding:12px 4px;border-radius:14px;
                            border:1px solid ${enabled ? border : 'rgba(255,255,255,0.05)'};
                            background:${enabled ? bg : 'rgba(255,255,255,0.02)'};
                            color:${enabled ? color : 'rgba(255,255,255,0.2)'};
                            font-size:12px;font-weight:500;
                            cursor:${enabled ? 'pointer' : 'not-allowed'};box-sizing:border-box;">
                            <ha-icon icon="${icon}" style="width:22px;height:22px;"></ha-icon>
                            <div>${label}</div>
                          </div>`;

                        const dBtn = (label, icon, color, bg, border, action='') => `
                          <div onclick="event.stopPropagation(); ${action}" style="flex:1;min-width:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;
                            padding:12px 4px;border-radius:14px;
                            border:1px solid ${border};background:${bg};color:${color};
                            font-size:12px;font-weight:500;cursor:pointer;box-sizing:border-box;">
                            <ha-icon icon="${icon}" style="width:22px;height:22px;"></ha-icon>
                            <div>${label}</div>
                          </div>`;

                        window._haDome_on = () => { window._globalHass.callService('switch','turn_on',{entity_id:'switch.master_power_dome'}); };
                        window._haDome_off = () => { window._globalHass.callService('switch','turn_off',{entity_id:'switch.master_power_dome'}); };
                        
                        window._haDomeFan_on = () => { window._globalHass.callService('switch','turn_on',{entity_id:'switch.dome_fans_socket_1'}); };
                        window._haDomeFan_off = () => { window._globalHass.callService('switch','turn_off',{entity_id:'switch.dome_fans_socket_1'}); };
                        
                        window._haDomeSrv_on = () => { window._globalHass.callService('switch','turn_on',{entity_id:'switch.blueai_screen_socket_1'}); };
                        window._haDomeSrv_off = () => { window._globalHass.callService('switch','turn_off',{entity_id:'switch.blueai_screen_socket_1'}); };

                        const turnOnAction  = `window._haDome_on(); window._haClose_dome();`;
                        const shutOffAction = `window._haDome_off(); window._haClose_dome();`;

                        return `
                          <div>
                            <div style="display:flex;align-items:center;gap:14px;margin-bottom:22px;">
                              <div style="width:52px;height:52px;border-radius:14px;background:rgba(6,182,212,0.18);
                                display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <ha-icon icon="mdi:dome-light" style="width:28px;color:#06b6d4;"></ha-icon>
                              </div>
                              <div style="flex:1;">
                                <div style="font-size:20px;font-weight:600;color:#ffffff;">Dome</div>
                                <div style="font-size:13px;margin-top:3px;">${statusHtml}</div>
                              </div>
                            </div>

                            <div style="font-size:11px;font-weight:600;color:rgba(232,237,248,0.35);letter-spacing:0.08em;margin-bottom:8px;">MASTER POWER</div>
                            <div style="display:flex;gap:8px;margin-bottom:16px;">
                              ${btn('Turn ON', 'mdi:power', '#4ade80', 'rgba(74,222,128,0.13)', 'rgba(74,222,128,0.28)', !online, turnOnAction)}
                              ${btn('Turn OFF', 'mdi:power-sleep', '#f87171', 'rgba(248,113,113,0.12)', 'rgba(248,113,113,0.26)', online, shutOffAction)}
                            </div>

                            <div style="border-top:1px solid rgba(255,255,255,0.08);margin-bottom:16px;"></div>

                            <div style="font-size:11px;font-weight:600;color:rgba(232,237,248,0.35);letter-spacing:0.08em;margin-bottom:8px;">COMPONENT CONTROL</div>
                            <div style="display:flex;gap:8px;margin-bottom:8px;">
                              ${dBtn('Fan ON','mdi:fan','#4ade80','rgba(74,222,128,0.13)','rgba(74,222,128,0.28)', 'window._haDomeFan_on()')}
                              ${dBtn('Fan OFF','mdi:fan-off','#f87171','rgba(248,113,113,0.12)','rgba(248,113,113,0.26)', 'window._haDomeFan_off()')}
                            </div>
                            <div style="display:flex;gap:8px;">
                              ${dBtn('Server ON','mdi:server','#4ade80','rgba(74,222,128,0.13)','rgba(74,222,128,0.28)', 'window._haDomeSrv_on()')}
                              ${dBtn('Server OFF','mdi:server-network-off','#f87171','rgba(248,113,113,0.12)','rgba(248,113,113,0.26)', 'window._haDomeSrv_off()')}
                            </div>
                          </div>
                        `;
                      ]]]
