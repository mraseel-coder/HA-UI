button_card_templates:
  glass_card:
    styles:
      card:
        - background: rgba(255, 255, 255, 0.07)
        - border: 1px solid rgba(255, 255, 255, 0.11)
        - border-radius: 20px
        - backdrop-filter: blur(32px) saturate(180%)
        - '-webkit-backdrop-filter': blur(32px) saturate(180%)
        - padding: 20px
        - box-shadow: none
        - color: '#e8edf8'
        - cursor: default
  section_heading:
    show_name: true
    show_icon: false
    styles:
      card:
        - background: transparent
        - border: none
        - box-shadow: none
        - padding: 20px 0 5px 5px
    name: |
      [[[
        return `
          <div style="display:flex; align-items:center; gap:10px;">
            <ha-icon icon="${variables.icon}" style="width:18px; color:rgba(232,237,248,0.5);"></ha-icon>
            <div style="font-size:14px; font-weight:600; color:rgba(232,237,248,0.5); letter-spacing:0.06em;">
              ${variables.title}
            </div>
          </div>
        `;
      ]]]
  pc_card:
    template: glass_card
    show_name: false
    show_icon: false
    triggers_update: all
    styles:
      grid:
        - grid-template-areas: '"header" "actions"'
        - grid-template-columns: 1fr
        - grid-template-rows: min-content min-content
    custom_fields:
      header:
        card:
          type: custom:button-card
          triggers_update: all
          show_name: true
          show_icon: false
          styles:
            card:
              - background: transparent
              - border: none
              - box-shadow: none
              - padding: 0
              - cursor: pointer
          name: |
            [[[
              const eid = variables.ping_entity;
              const s = eid ? states[eid] : null;
              const online = s && s.state === 'on';
              const offline = s && s.state === 'off';
              const statusHtml = online
                ? '<span style="color:#4ade80">● Online</span>'
                : offline
                  ? '<span style="color:#f87171">● Offline</span>'
                  : '<span style="color:rgba(255,255,255,0.35)">● Unknown</span>';
              return `
                <div style="display:flex; align-items:center; gap:14px; margin-bottom:16px;">
                  <div style="width:44px; height:44px; border-radius:12px; background:${variables.icon_bg}; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <ha-icon icon="${variables.pc_icon}" style="width:24px; color:${variables.theme_color};"></ha-icon>
                  </div>
                  <div style="text-align:left; display:flex; flex-direction:column; justify-content:center; flex:1;">
                    <div style="font-size:16px; font-weight:600; color:#ffffff; line-height:1.2;">${variables.pc_name}</div>
                    <div style="font-size:12px; color:rgba(232,237,248,0.5); margin-top:2px; line-height:1.2;">${statusHtml}</div>
                  </div>
                </div>
              `;
            ]]]
      actions:
        card:
          type: custom:button-card
          triggers_update: all
          show_name: true
          show_icon: false
          styles:
            card:
              - background: transparent
              - border: none
              - box-shadow: none
              - padding: 0
            name:
              - width: 100%
              - padding: 0
              - margin: 0
          name: |
            [[[
              window._globalHass = hass;
              const eid = variables.ping_entity;
              const s = eid ? states[eid] : null;
              const online = s && s.state === 'on';

              const btn = (label, icon, color, bg, border, enabled, action) => `
                <div onclick="event.stopPropagation(); ${enabled ? action : ''}"
                  style="flex:1; min-width:0; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px;
                  padding:10px 4px; border-radius:14px;
                  border:1px solid ${enabled ? border : 'rgba(255,255,255,0.05)'};
                  background:${enabled ? bg : 'rgba(255,255,255,0.02)'};
                  color:${enabled ? color : 'rgba(255,255,255,0.2)'};
                  font-size:11.5px; font-weight:500;
                  cursor:${enabled ? 'pointer' : 'not-allowed'}; box-sizing:border-box;"
                  onmousedown="${enabled ? "this.style.transform='scale(0.95)';this.style.filter='brightness(1.2)'" : ''}"
                  onmouseup="${enabled ? "this.style.transform='';this.style.filter=''" : ''}"
                  onmouseleave="${enabled ? "this.style.transform='';this.style.filter=''" : ''}">
                  <ha-icon icon="${icon}" style="width:20px; height:20px;"></ha-icon>
                  <div style="white-space:nowrap;">${label}</div>
                </div>
              `;

              const turnOnAction  = `window._globalHass.callService('script','turn_on',{entity_id:'${variables.turn_on_script}'});`;
              const shutOffAction = `window._globalHass.callService('button','press',{entity_id:'${variables.turn_off_btn}'});`;
              const restartAction = `window._globalHass.callService('button','press',{entity_id:'${variables.restart_btn}'});`;

              const powerLabel  = online ? 'Shut Off' : 'Turn ON';
              const powerIcon   = online ? 'mdi:power-sleep' : 'mdi:power';
              const powerColor  = online ? '#f87171' : '#4ade80';
              const powerBg      = online ? 'rgba(248,113,113,0.12)' : 'rgba(74,222,128,0.13)';
              const powerBorder = online ? 'rgba(248,113,113,0.26)' : 'rgba(74,222,128,0.28)';
              const powerAction = online ? shutOffAction : turnOnAction;

              return `
                <div style="display:flex; gap:8px; width:100%; box-sizing:border-box;">
                  ${btn(powerLabel, powerIcon, powerColor, powerBg, powerBorder, true, powerAction)}
                  ${btn('Restart', 'mdi:restart', '#fbbf24', 'rgba(251,191,36,0.12)', 'rgba(251,191,36,0.26)', online, restartAction)}
                </div>
              `;
            ]]]
